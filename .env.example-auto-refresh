# Configuration optionnelle pour Auto-Refresh System
# À ajouter dans votre .env file si vous voulez customiser

# Polling interval en millisecondes (dev: 0 = désactivé, prod: 30000 par défaut)
AUTO_REFRESH_POLLING_INTERVAL=30000

# Active le debug logging pour le système auto-refresh
AUTO_REFRESH_DEBUG=false

# Service Worker scope (par défaut: /)
SERVICE_WORKER_SCOPE=/

# Cache max age pour le manifest (en secondes, par défaut: 0 = no cache)
MANIFEST_CACHE_MAX_AGE=0

# Enable/disable Service Worker (true par défaut en prod)
ENABLE_SERVICE_WORKER=true
